# Firmcraft Dispatch Optimizer — environment configuration
# Copy to .env and fill in. The service reads these via src/config.py.

# --- Supabase (server-side: use the SERVICE ROLE key, not the anon key) ---
# The optimizer reads techs/jobs and writes dispatch_logs. The service_role key
# bypasses RLS, which is correct for a trusted server-side service.
SUPABASE_URL=https://qvocmbqgcdambvslmula.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Routes API (distance/duration matrix) ---
# Leave blank to force Haversine straight-line fallback (useful for local dev /
# CI where you don't want to spend API quota).
GOOGLE_MAPS_API_KEY=

# --- Redis (distance-matrix cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Distance cache / cost controls ---
# Grid-cell resolution for cache keys: 0.01 deg ~= 1.1 km.
DISTANCE_GRID_PRECISION=2
# Cache TTL in seconds (24h).
DISTANCE_CACHE_TTL=86400
# Circuit breaker: once estimated Google Routes spend for the day exceeds this
# (USD), fall back to cached-only + Haversine.
DISTANCE_DAILY_BUDGET_USD=15.0
# Google Routes Compute Route Matrix price per element (USD). Standard tier is
# $5 per 1000 elements = $0.005/element.
DISTANCE_COST_PER_ELEMENT=0.005

# --- Service ---
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
# Average metro driving speed (m/s) used for the Haversine duration fallback.
# 11.176 m/s ~= 25 mph, a realistic door-to-door city average.
FALLBACK_SPEED_MPS=11.176
