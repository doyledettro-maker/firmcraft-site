# Firmcraft central services — environment variables.
# Copy to .env and fill in. NEVER commit .env to git.
#
# Generate strong secrets with:  openssl rand -hex 32
# Generate base64 secrets with:  openssl rand -base64 32

# ─── Domains ──────────────────────────────────────────────────────────────────
LITELLM_DOMAIN=litellm.firmcraft.ai
LANGFUSE_DOMAIN=langfuse.firmcraft.ai

# Email Let's Encrypt uses for cert expiry warnings.
LETSENCRYPT_EMAIL=ops@firmcraft.ai

# ─── LiteLLM Postgres ─────────────────────────────────────────────────────────
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=CHANGEME_litellm_db_password

# ─── Langfuse Postgres (separate database) ────────────────────────────────────
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGEME_langfuse_db_password

# ─── LiteLLM secrets ──────────────────────────────────────────────────────────
# Master key — admin access to LiteLLM proxy. MUST start with "sk-".
LITELLM_MASTER_KEY=sk-CHANGEME_master_key_min_32_chars
# Salt for encrypting model API keys stored in LiteLLM's Postgres.
LITELLM_SALT_KEY=CHANGEME_litellm_salt_key_32_bytes_hex

# ─── Langfuse secrets ─────────────────────────────────────────────────────────
# NextAuth session secret. Generate: openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=CHANGEME_nextauth_secret_base64_32
# Salt for hashing API keys at rest. Generate: openssl rand -base64 32
LANGFUSE_SALT=CHANGEME_langfuse_salt_base64_32
# Encryption key for sensitive trace fields. MUST be 64 hex chars (32 bytes).
# Generate: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=CHANGEME_64_hex_chars_exactly_32_bytes_aaaaaaaaaaaaaaaaaaaaaaaaa
# Set to "true" once you've created the admin user; locks down the signup page.
LANGFUSE_DISABLE_SIGNUP=false

# Langfuse → LiteLLM observability callback. Mint these inside Langfuse UI:
#   Settings → Project → API Keys → Create new keys
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME

# ─── Provider API keys (used by LiteLLM router) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGEME
OPENAI_API_KEY=sk-CHANGEME
OPENROUTER_API_KEY=sk-or-CHANGEME
