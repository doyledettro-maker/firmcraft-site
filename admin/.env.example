# ----------------------------------------------------------------------------
# Firmcraft Admin — environment variables
# Copy to .env.local for dev; the same vars are set in Vercel for prod.
# ----------------------------------------------------------------------------

# --- Clerk (auth) -----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# --- Supabase ---------------------------------------------------------------
# URL is safe to expose (it's just the project hostname). The service role key
# must stay server-only — never reference it from client components.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
