# Scheduling skill configuration — copy to .env next to SKILL.md.
# The skill also honors these from the process environment (env wins over file).

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Which tenant this Hermes instance dispatches for (tenants.slug), or pin the
# UUID directly with SCHEDULING_TENANT_ID.
SCHEDULING_TENANT_SLUG=demo

# auto | always | never — whether to call the Edge Functions or go direct to
# PostgREST (auto probes deployment once per process and falls back).
SCHEDULING_EDGE_MODE=auto

# Audit attribution written to job_status_history.changed_by.
SCHEDULING_ACTOR=hermes
